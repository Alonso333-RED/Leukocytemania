theme_override_fonts/font = ExtResource("4_b1k3j")
theme_override_font_sizes/font_size = 64
text = "Los leucocitos, también llamados glóbulos blancos, son células de la sangre que forman parte del sistema inmunitario. Su función principal es proteger al organismo de infecciones, virus, bacterias y otras sustancias dañinas."
vertical_alignment = 1
autowrap_mode = 3

