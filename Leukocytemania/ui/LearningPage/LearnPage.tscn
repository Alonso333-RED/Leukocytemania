size_flags_horizontal = 3
size_flags_vertical = 1
theme_override_fonts/font = ExtResource("4_b1k3j")
theme_override_font_sizes/font_size = 64
text = "Cuando un microorganismo entra al cuerpo, los leucocitos lo detectan y lo combaten para evitar que cause enfermedades. Existen varios tipos de leucocitos, y cada uno cumple una función específica en la defensa del organismo."
vertical_alignment = 1
autowrap_mode = 3

